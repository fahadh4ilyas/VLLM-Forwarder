API_HOST=127.0.0.1
API_PORT=5000
WORKER_NUM=1
FORWARDED_ALLOW_IPS=127.0.0.1

# Required: prefix to scope all data (use different values for dev/prod)
NAME_PREFIX=vllm_dev

# Required (unless AUTHLESS_MODE=true): URL called by POST /apikey to verify user credentials
AUTH_URL=http://192.168.20.161:3931/service/otp/check

# Required (unless AUTHLESS_MODE=true): secret key for hashing API keys
SECRET_KEY=your-secret-key-here

# Optional: MongoDB connection (if set, replaces SQLite for all data)
# MONGO_URI=mongodb://user:pass@host:27017
# MONGO_DB=vllm_forwarder

# Optional: Kafka for usage logging
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_TOPIC=llm_usage_logs

# Optional: Enable authless mode (disables all API key auth, useful for dev)
# AUTHLESS_MODE=false

# Optional: Redis for caching database lookups (reduces DB load)
# USE_REDIS=false
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_AUTH=your-redis-password
